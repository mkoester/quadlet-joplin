[Unit]
Description=Joplin database (PostgreSQL)
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/postgres:16
AutoUpdate=registry

# postgres user in postgres:16 (Debian bookworm) runs as UID 999
# Verify: podman inspect docker.io/postgres:16 --format '{{.Config.User}}'
# then: podman run --rm --entrypoint grep docker.io/postgres:16 postgres /etc/passwd
UserNS=keep-id:uid=999,gid=999
User=999
Group=999

Network=joplin.network

# Environment variables — only POSTGRES_* vars are used by this container
EnvironmentFile=%h/.config/containers/systemd/joplin.env
EnvironmentFile=%h/.config/containers/systemd/joplin.override.env

# Persistent data volume
Volume=%h/db:/var/lib/postgresql/data:Z

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
